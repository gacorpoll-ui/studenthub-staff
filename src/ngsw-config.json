{
    "configVersion": 1,
    "version": 1,
    "index": "/index.html",
    "assetGroups": [
      {
        "installMode": "lazy",
        "name": "api",
        "resources" : {
          "urls": ["!/**/*.*"],
          "cacheConfig": {
              "strategy": "freshness",
              "maxSize": 0,
              "maxAge": "0u",
              "timeout": "21s"
          }
        }
      },
      {
        "installMode": "lazy",
        "name": "api",
        "resources" : {
          "urls": ["!/**/*.*"],
          "cacheConfig": {
              "strategy": "freshness",
              "maxSize": 0,
              "maxAge": "0u",
              "timeout": "21s"
          }
        }
      },
      {
        "name": "app",
        "installMode": "prefetch",
        "resources": {
          "files": [
            "/favicon.ico",
            "/index.html",
            "/*.css",
            "/*.js",
            "/*.svg"
          ]
        }
      },
      {
        "name": "assets",
